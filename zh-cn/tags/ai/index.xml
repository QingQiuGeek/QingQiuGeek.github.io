        <guid>/zh-cn/post/2026/02/reactagent%E5%92%8Cgraphagent/</guid>
        <description>&lt;p&gt;&lt;img src=&#34;/zh-cn/post/2026/02/reactagent%E5%92%8Cgraphagent/image.png&#34;
	width=&#34;1438&#34;
	height=&#34;662&#34;
	srcset=&#34;/zh-cn/post/2026/02/reactagent%E5%92%8Cgraphagent/image_hu_32b15758dd3b509c.png 480w, /zh-cn/post/2026/02/reactagent%E5%92%8Cgraphagent/image_hu_3f8e878e9a3a5774.png 1024w&#34;
